---
const base = "https://github.com/PatrykQuantumNomad/kinder/releases/latest/download/kinder";
---

<div class="install-command not-content">
  <code class="command-text"></code>
  <button class="copy-btn">Copy</button>
</div>

<script define:vars={{ base }}>
  async function detectBinary() {
    const ua = navigator.userAgent.toLowerCase();
    let os = "linux";
    if (ua.includes("mac")) os = "darwin";
    else if (ua.includes("win")) os = "windows";

    let arch = "amd64";
    if (navigator.userAgentData && navigator.userAgentData.getHighEntropyValues) {
      try {
        const hints = await navigator.userAgentData.getHighEntropyValues(["architecture"]);
        if (hints.architecture === "arm") arch = "arm64";
      } catch {}
    } else if (ua.includes("arm64") || ua.includes("aarch64")) {
      arch = "arm64";
    }

    return `${base}-${os}-${arch}`;
  }

  async function init() {
    const url = await detectBinary();
    const command = `curl -Lo kinder ${url} && chmod +x kinder && sudo mv kinder /usr/local/bin/`;

    const code = document.querySelector(".command-text");
    if (code) code.textContent = command;

    const btn = document.querySelector(".copy-btn");
    if (btn) {
      btn.addEventListener("click", () => {
        navigator.clipboard.writeText(command).then(() => {
          btn.textContent = "Copied!";
          setTimeout(() => { btn.textContent = "Copy"; }, 2000);
        });
      });
    }
  }

  init();
</script>

<style>
  .install-command {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: var(--sl-color-black);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.375rem;
    padding: 0.75rem 1rem;
    margin-block: 1.5rem;
    max-width: 42rem;
  }

  .command-text {
    font-family: var(--sl-font-mono);
    font-size: var(--sl-text-sm);
    color: var(--sl-color-accent-high);
    overflow-x: auto;
    white-space: nowrap;
    flex: 1;
  }

  .copy-btn {
    background: var(--sl-color-accent);
    color: var(--sl-color-black);
    border: none;
    border-radius: 0.25rem;
    padding: 0.25rem 0.625rem;
    font-weight: 600;
    cursor: pointer;
    flex-shrink: 0;
  }

  .copy-btn:hover {
    background: var(--sl-color-accent-high);
  }

  @media (max-width: 50rem) {
    .install-command {
      flex-direction: column;
      align-items: stretch;
      max-width: 100%;
    }

    .copy-btn {
      width: 100%;
      padding: 0.5rem 0.625rem;
    }
  }
</style>
